# Required: Gemini API key
GEMINI_API_KEY=your_gemini_api_key

# Preferred provider
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Optional alternative provider (preferred if set)
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional: model names
GEMINI_MODEL=gemini-flash-latest
GEMINI_HTTP_MODEL=gemini-flash-latest

# Optional: AgentVault server URL
AGENTVAULT_URL=http://localhost:3500

# Required in live x402 mode (optional in X402_MOCK=true)
STORAGE_PRIVATE_KEY=0x...

# Optional: deterministic test keys for agent identities
RESEARCH_AGENT_PK=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
INFERENCE_AGENT_PK=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d
