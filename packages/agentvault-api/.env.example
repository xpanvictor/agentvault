# Integration test target
# Fallback in test code is http://localhost:3500
BaseAgentVaultUrl=http://localhost:3500

# Signing key used by integration tests for:
# - register-agent signature generation
# - x402 payment signing (when AGENTVAULT_TEST_XPAYMENT_HEADER is not set)
#
# Use a funded Calibration wallet key for real x402 mode.
# In X402_MOCK=true mode, this can still be set for registration.
AGENTVAULT_TEST_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Optional: provide pre-signed x-payment headers.
# Nonce is one-time use, so use distinct signatures for store/retrieve.
# AGENTVAULT_TEST_XPAYMENT_HEADER_STORE={"from":"0x...","to":"0x...","value":"10000","validAfter":0,"validBefore":9999999999,"nonce":"0x...","signature":"0x...","token":"0x..."}
# AGENTVAULT_TEST_XPAYMENT_HEADER_RETRIEVE={"from":"0x...","to":"0x...","value":"10000","validAfter":0,"validBefore":9999999999,"nonce":"0x...","signature":"0x...","token":"0x..."}

# Backward compatibility: AGENTVAULT_TEST_XPAYMENT_HEADER is used as STORE header.
# If this header is stale/invalid/non-JSON, tests now retry with signer flow.
# AGENTVAULT_TEST_XPAYMENT_HEADER={"from":"0x...","to":"0x...","value":"10000","validAfter":0,"validBefore":9999999999,"nonce":"0x...","signature":"0x...","token":"0x..."}

# Optional: override EIP-712 token domain used by ViemX402PaymentSigner.
# Test default is tokenName=USDFC and tokenVersion=1.
# Only set these if your FIL-x402 verifier expects different domain values.
# AGENTVAULT_TEST_TOKEN_NAME=USD FileCoin
# AGENTVAULT_TEST_TOKEN_VERSION=1
