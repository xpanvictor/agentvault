{
  "name": "@agent_vaults/api-client",
  "version": "0.1.0",
  "description": "Type-safe AgentVault SDK for identity, verifiable memory, and x402 payment flows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:demo": "AGENTVAULT_TEST_DEMO_LOGS=true vitest run --config vitest.config.ts --reporter verbose --testNamePattern end-to-end"
  },
  "keywords": [
    "agentvault",
    "filecoin",
    "x402",
    "usdfc",
    "agent-memory",
    "agent-identity",
    "sdk",
    "typescript"
  ],
  "author": "AgentVault",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpanvictor/agentvault.git",
    "directory": "packages/agentvault-api"
  },
  "homepage": "https://github.com/xpanvictor/agentvault/tree/master/packages/agentvault-api",
  "bugs": {
    "url": "https://github.com/xpanvictor/agentvault/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "viem": "2.x"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "dotenv": "^16.4.7",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
}
