# AgentVault Configuration

# Server
PORT=3500
HOST=0.0.0.0

# FIL-x402 API (payment infrastructure)
X402_API_URL=http://localhost:3402
X402_API_TIMEOUT=30000
# Mock mode: skip real verification (for local dev without FIL-x402)
X402_MOCK=false

# Facilitator (receives storage payments)
# IMPORTANT: Set this to your wallet address
FACILITATOR_ADDRESS=0x0000000000000000000000000000000000000000

# Storage Provider
STORAGE_PROVIDER=mock
# STORAGE_PROVIDER=synapse
# Wallet private key for Synapse SDK authentication (no API key needed)
# STORAGE_PRIVATE_KEY=0x...

# Agent Identity (ERC-8004)
IDENTITY_ENABLED=false
# IDENTITY_REGISTRY_ADDRESS=0x...

# Filecoin Network
FILECOIN_NETWORK=calibration
# Chain ID: 314159 (Calibration) or 314 (Mainnet)
FILECOIN_CHAIN_ID=314159
# WebSocket RPC for Synapse SDK
FILECOIN_RPC_URL=wss://wss.calibration.node.glif.io/apigw/lotus/rpc/v1
# USDFC token contract
USDFC_ADDRESS=0xb3042734b608a1B16e9e86B374A3f3e389B4cDf0

# Logging
LOG_LEVEL=info
