# AgentVault Configuration

# Server
PORT=3500
HOST=0.0.0.0

# FIL-x402 API (payment infrastructure)
X402_API_URL=http://localhost:3402
X402_API_TIMEOUT=30000

# Storage (choose one)
STORAGE_PROVIDER=mock
# STORAGE_PROVIDER=web3storage
# WEB3_STORAGE_TOKEN=your_token_here

# Agent Identity
IDENTITY_ENABLED=false
# IDENTITY_REGISTRY_ADDRESS=0x...
# IDENTITY_CHAIN_RPC=https://sepolia.base.org

# Filecoin
FILECOIN_NETWORK=calibration
FILECOIN_RPC=https://api.calibration.node.glif.io/rpc/v1

# Logging
LOG_LEVEL=info
